{
  "name": "document-query-engine",
  "version": "0.1.0",
  "private": true,
  "description": "Workshop: structured query synthesis (NL -> MongoDB) over GitHub PR/Issue data",
  "type": "module",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "db:init": "bun src/cli/init-db.ts",
    "ingest": "bun src/cli/ingest.ts",
    "serve": "bun --watch src/server/serve.ts",
    "test": "vitest run"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@octokit/rest": "^21.0.2",
    "express": "^4.21.2",
    "marked": "^12.0.0",
    "mongodb": "^6.12.0",
    "openai": "^6.45.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.5",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  },
  "engines": {
    "bun": ">=1.1"
  }
}

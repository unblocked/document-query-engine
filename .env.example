# GitHub token for ingestion. Optional — if blank, the `gh` CLI token is used
# (run `gh auth login`). Or paste a personal access token (public_repo / repo scope).
GITHUB_TOKEN=

# LLM for query synthesis + the chat agent. Set ONE of the two below.
# If OPENAI_API_KEY is set, the engine uses OpenAI; otherwise it uses Anthropic.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Local MongoDB connection
MONGO_URI=mongodb://localhost:27017
MONGO_DB=workshop

# Your GitHub login — treated as "me" / "my" in natural-language queries
CALLER_LOGIN=
